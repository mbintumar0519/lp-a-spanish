# =====================================================================
#  Lp(a) Cardiovascular Study — Spanish Landing Page — environment variables
# =====================================================================
#
#  HOW TO USE
#  ----------
#  1. Copy this file:      cp .env.example .env.local
#  2. Fill in the values.  All keys below are REQUIRED.
#  3. Validate:            npm run env:check  (if available)
#  4. Dev / build:         npm run dev   /   npm run build
#
#  SECURITY
#  --------
#  .env.local is git-ignored. NEVER commit real values. This file ships
#  placeholder text only — values shown here are NOT real credentials.
#
#  KEY TYPES
#  ---------
#  - NEXT_PUBLIC_*  -> inlined into the browser bundle; safe to expose
#                     (these are public IDs, not secrets).
#  - GOHIGHLEVEL_*, FACEBOOK_ACCESS_TOKEN, etc.
#                   -> server-only; never sent to the browser.
# =====================================================================


# =====================================================================
#  SERVER-ONLY — never prefix with NEXT_PUBLIC_
# =====================================================================

# ---- GoHighLevel CRM API key ---------------------------------------
# Where: GoHighLevel -> Settings (Location level) -> Business Info
#        OR Agency level -> Agency Settings -> API Keys
# Format: a JWT string starting with "eyJ"
# Doc:   https://highlevel.stoplight.io/docs/integrations
# IMPORTANT: This must be the v1 Location API key, not the v2 key.
GOHIGHLEVEL_API_KEY=your-ghl-jwt-token-here


# ---- GoHighLevel Location ID (optional but recommended) ------------
# Where: GoHighLevel -> Settings -> Business Info -> Location ID
# Used for: validating API context and some v2 endpoints
GOHIGHLEVEL_LOCATION_ID=your-ghl-location-id-here


# ---- GoHighLevel Calendar ID ---------------------------------------
# Where: GoHighLevel -> Calendars -> your calendar -> Settings
# Used for: generating one-time booking links
GOHIGHLEVEL_CALENDAR_ID=your-calendar-id-here


# ---- Meta (Facebook) Conversions API token --------------------------
# Where: Meta Events Manager -> Data Sources -> your Pixel
#        -> Settings -> "Generate Access Token"
# Use:   A System-User token with scopes: ads_management, business_management
# Doc:   https://developers.facebook.com/docs/marketing-api/conversions-api
FACEBOOK_ACCESS_TOKEN=your-meta-capi-system-user-token-here


# ---- Meta (Facebook) Pixel ID (server-side copy) -------------------
# Where: Meta Events Manager -> Data Sources -> your Pixel -> Details
#        (also the same value used in NEXT_PUBLIC_FACEBOOK_PIXEL_ID below)
# Format: 15-16 digit number, e.g. 565214965918509
FACEBOOK_PIXEL_ID=your-facebook-pixel-id-here


# ---- Meta Conversions API version ----------------------------------
# Default is fine. Only change if Meta deprecates a version.
# Doc:   https://developers.facebook.com/docs/graph-api/overview
FACEBOOK_API_VERSION=v19.0


# ---- Meta Test Event Code (optional — development only) --------------
# Where: Meta Events Manager -> Test Events tab -> Generate Test Event Code
# Use:   During development to see events marked as "Test" in Events Manager
FACEBOOK_TEST_EVENT_CODE=TEST12345


# ---- IP Geolocation API key ----------------------------------------
# Where: https://ipgeolocation.io/ -> Dashboard -> API Key
# Use:   Automatically enriches leads with city, state, zip code
# Free tier includes 1,000 requests/day
IP_GEOLOCATION_API_KEY=your-ipgeolocation-api-key-here


# ---- Google Sheets Webhook URL -------------------------------------
# Where: Google Apps Script deployment URL
# Use:   Backup lead storage to Google Sheets (non-blocking)
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec


# =====================================================================
#  PUBLIC — safe to expose to the browser (NEXT_PUBLIC_*)
# =====================================================================

# ---- Meta (Facebook) Pixel ID (browser-side) -----------------------
# Same value as FACEBOOK_PIXEL_ID above.
# Where: Meta Events Manager -> Data Sources -> your Pixel -> Details
NEXT_PUBLIC_FACEBOOK_PIXEL_ID=your-facebook-pixel-id-here


# ---- GoHighLevel Calendar Embed URL (browser-side) -----------------
# Where: GoHighLevel -> Calendars -> your calendar -> "Booking Widget"
# Format: https://api.leadconnectorhq.com/widget/booking/YOUR_CALENDAR_ID
NEXT_PUBLIC_GOHIGHLEVEL_CALENDAR_EMBED_URL=https://api.leadconnectorhq.com/widget/booking/YOUR_CALENDAR_ID


# ---- Site URL ------------------------------------------------------
# Your production site URL (used for sitemap, OG tags, etc.)
NEXT_PUBLIC_SITE_URL=https://your-site-url.com


# =====================================================================
#  OPTIONAL — only needed for local debugging
# =====================================================================

# NODE_ENV=development
